# ============================================================
# Mai Chi English API — environment template
# Copy to .env and fill in real values. Do NOT commit .env.
# ============================================================

# Supabase Postgres connection.
# Get from: Supabase Dashboard → Project Settings → Database → Connection string.
# Use the "Session pooler" (port 5432) or direct connection — NOT the
# "Transaction pooler" (port 6543), which does not support asyncpg's
# extended query protocol.
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# Set true for verbose logging in local dev.
DEBUG=false

# Optional app metadata (defaults are reasonable).
# APP_NAME=Mai Chi English API
# PORT=8000

# Supabase Storage credentials — REQUIRED for the media upload endpoint
# (POST /api/admin/upload). Get from Supabase Dashboard → Project Settings → API.
SUPABASE_URL=https://[PROJECT].supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Storage backend selector. Default "supabase". Change to "s3" when the
# S3 adapter is implemented (currently a stub).
# STORAGE_PROVIDER=supabase

# Comma-separated list of exact-match CORS origins (e.g. localhost dev).
CORS_ORIGINS=http://localhost:3000

# Regex for matching Vercel deployments (production + dev + previews).
# Default covers the production and dev Vercel projects plus all their
# preview URLs:
#   https://maichienglish.vercel.app           (production)
#   https://dev-maichienglish.vercel.app       (dev)
#   https://maichienglish-frontend.vercel.app  (legacy)
#   https://maichienglish-<hash>-<team>.vercel.app       (preview)
#   https://dev-maichienglish-<hash>-<team>.vercel.app   (preview)
CORS_ORIGIN_REGEX=^https://(dev-)?maichienglish(-[\w-]+)?\.vercel\.app$

# JWT signing secret. REQUIRED in production.
# Generate locally with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change-me-in-prod
JWT_ALGORITHM=HS256
JWT_ACCESS_EXP_MINUTES=60
JWT_REFRESH_EXP_DAYS=7
JWT_ISSUER=maichienglish
JWT_AUDIENCE=maichienglish

# Initial admin user — only consumed by scripts/seed_admin.py.
# Used once to bootstrap the first admin; not read at runtime.
# NOTE: must be a real-world TLD. Reserved TLDs like .local / .test / .example
# / .invalid are rejected by the email-validator library.
ADMIN_EMAIL=admin@maichienglish.com
ADMIN_PASSWORD=change-me
ADMIN_FULL_NAME=Mai Chi Admin
